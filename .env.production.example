# ── Japan Real Estate Intel MCP — Production (.env.production) ─────────────
# 用途に応じて下の2パターンのどちらかをコピーして使う。docker-compose.yml が
# `env_file: .env.production` で読み込む（docker-compose.yml 自体は編集不要）。
#
#   パターン1: Claude Connectors Directory 等の「公開ディレクトリ経由」で
#              接続させる公開インスタンス → API_KEY は必ず未設定のままにする
#              （authless 前提。設定すると /mcp が 401 を返しディレクトリ経由の
#              接続が全て失敗する）。
#   パターン2: 自分だけ／社内だけで使う自己ホスト → API_KEY を設定して
#              /mcp・/artifacts 等を保護する。
#
# どちらのパターンでも、公開URLを外部に晒すには Caddy か Cloudflare Tunnel の
# いずれかのプロファイルで起動する必要がある（`docker compose up -d` を
# プロファイル無しで実行すると mcp コンテナは他コンテナと同じ Docker
# ネットワーク内にしか公開されず、外部からアクセスできない）。
#   docker compose --profile caddy up -d --build    # 独自ドメイン + 自動HTTPS
#   docker compose --profile tunnel up -d --build    # NAT配下 / パブリックIP不要
# 詳細: docs/deploy.md

# ── HTTP transport 認証 ──────────────────────────────────────────────────────
# パターン1（公開ディレクトリ経由）: 未設定のままにする（コメントアウトを維持）
# パターン2（自己ホスト保護）: 強力なランダム値を設定する
#   openssl rand -hex 32
# API_KEY=

# ── 公開URL（resource_link / ダッシュボード直リンク生成に使用）────────────────
# 末尾スラッシュ不要。Caddyfile のドメインと一致させる
MCP_PUBLIC_URL=https://your-domain.example.com

# ── Caddy (Option A: 独自ドメイン + 自動HTTPS) ──────────────────────────────
# Caddyfile の1行目に同じドメインを設定すること（scripts/deploy.sh が自動編集）

# ── Cloudflare Tunnel (Option B: NAT配下 / パブリックIP不要) ─────────────────
# Zero Trust > Access > Tunnels > Create で取得したトークン
# TUNNEL_TOKEN=

# ── アーティファクト永続化（generate_area_report のPDF等）───────────────────
# docker-compose.yml が rei_sqlite ボリューム内を指すよう既定で設定済み。
# 変更する場合のみ上書きする
# ARTIFACT_DIR=/app/db/artifacts
# ARTIFACT_TTL_HOURS=24

# ── Pro/Enterprise ライセンス発行（Stripe課金運用時のみ）───────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# LICENSE_PRIVATE_KEY_PEM=

# ── 外部データAPI（任意・未設定でもモック/フォールバックで動作）─────────────
# ESTAT_APP_ID=
# MLIT_API_KEY=
# GOOGLE_GENAI_API_KEY=
# GOOGLE_MAPS_API_KEY=

# ── メトリクス保護（/metrics、API_KEYと独立）─────────────────────────────────
# METRICS_KEY=

# ── エラートラッキング（任意）────────────────────────────────────────────────
# SENTRY_DSN=

# ── ログレベル ───────────────────────────────────────────────────────────────
# LOG_LEVEL=info
