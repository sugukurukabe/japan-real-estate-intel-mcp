# ── Japan Real Estate Intel — Caddyfile ──────────────────────────────────────
# Domain: realestate-mcp.jp
# Caddy automatically obtains and renews TLS certificates via Let's Encrypt.
# To change the domain later: edit the first line, then run
#   docker compose exec caddy caddy reload --config /etc/caddy/Caddyfile

realestate-mcp.jp, www.realestate-mcp.jp {
    # Reverse-proxy all traffic to the MCP server
    reverse_proxy mcp:3100

    # Optional: Compress responses
    encode zstd gzip

    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    # Health check endpoint (no auth required)
    handle /health {
        reverse_proxy mcp:3100
    }

    # Static dashboard files served by MCP's Express static handler
    handle /dashboard* {
        reverse_proxy mcp:3100
    }

    # MCP endpoint
    handle /mcp* {
        reverse_proxy mcp:3100
    }

    log {
        output stdout
        format json
    }
}
