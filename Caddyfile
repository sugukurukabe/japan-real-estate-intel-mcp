# ── Japan Real Estate Intel — Caddyfile ──────────────────────────────────────
# Replace your-domain.com with your actual domain.
# Caddy automatically obtains and renews TLS certificates via Let's Encrypt.

your-domain.com {
    # Reverse-proxy all traffic to the MCP server
    reverse_proxy mcp:3100

    # Optional: Compress responses
    encode zstd gzip

    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    # Health check endpoint (no auth required)
    handle /health {
        reverse_proxy mcp:3100
    }

    # Static dashboard files served by MCP's Express static handler
    handle /dashboard* {
        reverse_proxy mcp:3100
    }

    # MCP endpoint
    handle /mcp* {
        reverse_proxy mcp:3100
    }

    log {
        output stdout
        format json
    }
}

# Redirect www to apex (optional)
# www.your-domain.com {
#     redir https://your-domain.com{uri} permanent
# }
