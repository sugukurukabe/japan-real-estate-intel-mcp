# e-Stat API (政府統計API) — https://www.e-stat.go.jp/api/ で無料取得
ESTAT_APP_ID=your_estat_app_id_here

# MLIT 不動産情報ライブラリAPI — https://www.reinfolib.mlit.go.jp/help/apiManual/ で無料取得（任意）
# detect_arbitrage_signals の最新取引価格取得に使用。未設定でもモックデータで動作。
# MLIT_API_KEY=your_mlit_api_key_here

# Google Gemini API (任意: AI narrative / Vision 画像分析に使用)
# https://ai.google.dev/gemini-api/docs で取得。変数名は GOOGLE_GENAI_API_KEY（GEMINI_API_KEY ではない）。
# GOOGLE_GENAI_API_KEY=your_gemini_api_key_here

# Google Maps API (任意: Street View / Distance Matrix に使用)
# assess_exterior_visuals, analyze_commute_accessibility で使用。未設定でもシミュレーション結果にフォールバック。
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# BigQuery (任意: 大規模データセットをBigQuery経由で提供する場合のみ)
# GCP_PROJECT=your_gcp_project_id
# BQ_DATASET=japan_real_estate

# ── HTTP transport 認証（自己ホスト時のみ; ディレクトリ経由の公開接続では未設定を推奨） ──────
# 設定すると /mcp 等が X-Api-Key ヘッダー（または Authorization: Bearer）を要求する
# API_KEY=your_http_api_key_here

# MCP tier: free | pro | enterprise (stdio / self-hosted). Public remote defaults to free.
# DEFAULT_TIER=free
# Pro demo only (internal): DEFAULT_TIER=pro — see docs/pro-demo-setup.md
# LICENSE_KEY is required to unlock pro/enterprise tiers (self-hosted / remote).
# Contact support@sugu-kuru.co.jp to obtain a valid license key.
# LICENSE_KEY=your_signed_license_key_here
# Free monthly tool-call soft limit (default 50); pro/enterprise unlimited
# TIER_MONTHLY_TOOL_CALLS=50
# USAGE_CLIENT_ID=optional-client-key-for-quota-buckets
# USAGE_DB_PATH=./db/usage.sqlite

# ツール内のダッシュボード直リンク・resource_link 生成に使用（末尾スラッシュ不要、本番URLに合わせる）
# MCP_PUBLIC_URL=https://realestate-mcp.jp

# ── Metrics ─────────────────────────────────────────────────────────────────
# Prometheus /metrics is always key-gated (independent of API_KEY). If unset
# and API_KEY is also unset, /metrics responds 404.
# METRICS_KEY=your_metrics_key_here

# ── Report/CSV artifacts (src/artifacts.ts) ────────────────────────────────
# Downloadable PDF/CSV/Markdown exports (generate_area_report, portfolio_optimizer,
# etc.) are saved here and served via /artifacts/:id/:filename (HTTP transport)
# or the artifact://{id} MCP resource (stdio transport). TTL-cleaned; never commit.
# ARTIFACT_DIR=./artifacts
# ARTIFACT_DB_PATH=./db/artifacts.sqlite
# ARTIFACT_TTL_HOURS=24

# ── Stripe Billing ──────────────────────────────────────────────────────────
# Stripe secret key (sk_test_... for test mode, sk_live_... for production)
# STRIPE_SECRET_KEY=sk_test_xxx
# Stripe webhook signing secret (whsec_...)
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── License Key Signing / Verification ──────────────────────────────────────
# ECDSA prime256v1 private key for signing license keys.
# Generate with: openssl ecparam -genkey -name prime256v1 -noout -out private.pem
# Then set as env var (use \n for newlines):
# LICENSE_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\nMIGH...\n-----END PRIVATE KEY-----
# LICENSE_DB_PATH=./db/licenses.sqlite
# Legacy online license-verification fallback endpoint (verifyLicenseKeyOffline,
# used by getRequestTier, does not call this; only the older verifyLicenseKey() does)
# LICENSE_SERVER_URL=https://api.realestate-mcp.jp/licenses/validate

# ── Server runtime (Dockerfile / docker-compose already set sensible defaults) ──
# PORT=3100
# HOST=0.0.0.0
# NODE_ENV=production
# LOG_LEVEL=info
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=900000
# SESSION_TIMEOUT_MS=1800000

# ── Error tracking (optional) ───────────────────────────────────────────────
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
