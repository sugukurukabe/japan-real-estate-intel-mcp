# e-Stat API (政府統計API) — https://www.e-stat.go.jp/api/ で無料取得
ESTAT_APP_ID=your_estat_app_id_here

# Google Gemini API (任意: AI narrative 生成に使用)
# GEMINI_API_KEY=your_gemini_api_key_here

# MLIT 不動産取引価格API (認証不要・任意設定)
# MLIT_BASE_URL=https://www.land.mlit.go.jp/webland/api

# 本番・ステージングで必ず実 URL に合わせる（未設定時のデフォルトは開発向け）
# BASE_URL=https://your-mcp-host.example.com
# OAuth 発行 URL・ツール内のダッシュボード直リンク等（末尾スラッシュ不要）
# MCP_PUBLIC_URL=https://realestate-mcp.jp
