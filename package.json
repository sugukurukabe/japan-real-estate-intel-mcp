{
  "name": "@sugukuru/japan-real-estate-intel-mcp",
  "version": "7.0.0",
  "description": "Japan real estate intelligence connector - land price, transactions, population, zoning, vacancy, population projection, disaster risk, human flow, education, corporate location cross-analysis (10 prefectures: Aichi/Tokyo/Osaka/Fukuoka/Hokkaido/Kanagawa/Kyoto/Hyogo/Chiba/Saitama)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "japan-real-estate-intel-mcp": "dist/index.js",
    "japan-real-estate-intel-mcp-http": "dist/http.js"
  },
  "files": [
    "dist",
    "data",
    "ui",
    "assets",
    "config",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc && npm run build:ui",
    "build:server": "npm run clean && tsc",
    "build:ui": "node scripts/build-ui.js",
    "lint:ui": "tsc -p ui-src/tsconfig.json",
    "dev:ui": "vite --config ui-src/vite.config.ts",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "data:fetch": "tsx scripts/fetch-real-data.ts",
    "data:fetch:all": "tsx scripts/fetch-real-data.ts --all --year 2025",
    "ui:gen": "tsx scripts/generate-ui-prefecture-data.ts",
    "fonts:download": "node scripts/download-fonts.js",
    "screenshots": "node scripts/capture-dashboard-screenshots.mjs",
    "verify:ui": "node scripts/verify-dashboard-smoke.mjs",
    "demo:record": "node scripts/record-demo-video.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "real-estate",
    "aichi",
    "japan",
    "tokyo",
    "human-flow",
    "education",
    "corporate",
    "land-price",
    "hazard",
    "investment",
    "rosenka",
    "arbitrage"
  ],
  "author": "sugukuru",
  "license": "AGPL-3.0-only",
  "mcpName": "io.github.sugukurukabe/japan-real-estate-intel-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/sugukurukabe/japan-real-estate-intel-mcp.git"
  },
  "homepage": "https://realestate-mcp.jp",
  "bugs": {
    "url": "https://github.com/sugukurukabe/japan-real-estate-intel-mcp/issues"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3",
      "sharp"
    ]
  },
  "dependencies": {
    "@google-cloud/bigquery": "^8.3.1",
    "@google/genai": "^2.7.0",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@sentry/node": "^10.56.0",
    "@turf/boolean-point-in-polygon": "^7.2.0",
    "@turf/helpers": "^7.2.0",
    "better-sqlite3": "^12.10.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "papaparse": "^5.5.2",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "stripe": "^22.2.0",
    "suncalc": "^1.9.0",
    "topojson-client": "^3.1.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.2",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.1.1",
    "@types/papaparse": "^5.3.15",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/suncalc": "^1.9.2",
    "@types/supertest": "^7.2.1",
    "@types/three": "^0.185.1",
    "@types/topojson-client": "^3.1.5",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "leaflet": "^1.9.4",
    "playwright": "1.61.1",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "supertest": "^7.2.2",
    "three": "^0.185.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.10"
  }
}
