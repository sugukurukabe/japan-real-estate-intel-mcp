{
  "name": "@sugukuru/japan-real-estate-intel-mcp",
  "version": "2.3.0",
  "description": "日本の不動産投資・仲介・開発・管理向けに地価・取引価格・人口統計・災害リスク・人流・教育・企業立地をクロス分析するMCPサーバー（愛知県・東京都対応、都道府県プラガブル構造）",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "japan-real-estate-intel-mcp": "dist/index.js",
    "japan-real-estate-intel-mcp-http": "dist/http.js"
  },
  "files": [
    "dist",
    "data",
    "ui",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc && node scripts/build-ui.js",
    "build:server": "npm run clean && tsc",
    "build:ui": "node scripts/build-ui.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "real-estate",
    "aichi",
    "japan",
    "tokyo",
    "human-flow",
    "education",
    "corporate",
    "land-price",
    "hazard",
    "investment"
  ],
  "author": "sugukuru",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@turf/boolean-point-in-polygon": "^7.2.0",
    "@turf/helpers": "^7.2.0",
    "express": "^5.1.0",
    "papaparse": "^5.5.2",
    "suncalc": "^1.9.0",
    "topojson-client": "^3.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^22.15.3",
    "@types/papaparse": "^5.3.15",
    "@types/suncalc": "^1.9.2",
    "@types/topojson-client": "^3.1.5",
    "esbuild": "^0.25.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
