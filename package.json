{
  "name": "@sugukuru/japan-real-estate-intel-mcp",
  "version": "6.15.0",
  "description": "Japan real estate intelligence MCP - land price, transactions, population, zoning, vacancy, population projection, disaster risk, human flow, education, corporate location cross-analysis (10 prefectures: Aichi/Tokyo/Osaka/Fukuoka/Hokkaido/Kanagawa/Kyoto/Hyogo/Chiba/Saitama)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "japan-real-estate-intel-mcp": "dist/index.js",
    "japan-real-estate-intel-mcp-http": "dist/http.js"
  },
  "files": [
    "dist",
    "data",
    "ui",
    "assets",
    "config",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc && node scripts/build-ui.js",
    "build:server": "npm run clean && tsc",
    "build:ui": "node scripts/build-ui.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "data:fetch": "tsx scripts/fetch-real-data.ts",
    "data:fetch:all": "tsx scripts/fetch-real-data.ts --all --year 2025",
    "ui:gen": "tsx scripts/generate-ui-prefecture-data.ts",
    "fonts:download": "node scripts/download-fonts.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "real-estate",
    "aichi",
    "japan",
    "tokyo",
    "human-flow",
    "education",
    "corporate",
    "land-price",
    "hazard",
    "investment",
    "rosenka",
    "arbitrage"
  ],
  "author": "sugukuru",
  "license": "MIT",
  "mcpName": "jp.realestate-mcp/server",
  "repository": {
    "type": "git",
    "url": "https://github.com/sugukuru/japan-real-estate-intel-mcp.git"
  },
  "homepage": "https://realestate-mcp.jp",
  "bugs": {
    "url": "https://github.com/sugukuru/japan-real-estate-intel-mcp/issues"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3",
      "sharp"
    ]
  },
  "dependencies": {
    "@google-cloud/bigquery": "^8.3.0",
    "@google/genai": "^2.0.1",
    "@modelcontextprotocol/ext-apps": "^1.7.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@sentry/node": "^10.52.0",
    "@turf/boolean-point-in-polygon": "^7.2.0",
    "@turf/helpers": "^7.2.0",
    "better-sqlite3": "^12.9.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "papaparse": "^5.5.2",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "suncalc": "^1.9.0",
    "topojson-client": "^3.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.2",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.7.0",
    "@types/papaparse": "^5.3.15",
    "@types/pdfkit": "^0.17.6",
    "@types/suncalc": "^1.9.2",
    "@types/supertest": "^7.2.0",
    "@types/topojson-client": "^3.1.5",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}

